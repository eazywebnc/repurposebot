{
  "name": "repurposebot",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "vars": {
    "NEXT_PUBLIC_SUPABASE_URL": "https://mgiamamqrvfcfqzlqtcs.supabase.co",
    "NEXT_PUBLIC_APP_URL": "https://repurposebot.eazyweb.nc"
  },
  "routes": [
    {
      "pattern": "repurposebot.eazyweb.nc",
      "custom_domain": true
    }
  ]
}
